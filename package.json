{
  "name": "boilerplate-frontend-react",
  "description": "Boilerplate Frontend in React",
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "deploy": "npm run build && npm run html-min",
    "html-min": "html-minifier --input-dir public --output-dir public --file-ext html --remove-comments --collapse-whitespace",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "engines": {
    "node": ">=24.11.1",
    "npm": ">=11.6.2"
  },
  "dependencies": {
    "@fixhq/react-audio-voice-recorder": "2.2.100",
    "@hookform/resolvers": "5.2.2",
    "axios": "1.15.0",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "buffer": "6.0.3",
    "lodash": "4.18.1",
    "react": "19.2.5",
    "react-bootstrap": "2.10.10",
    "react-confetti": "6.4.0",
    "react-dom": "19.2.5",
    "react-easy-crop": "5.5.7",
    "react-hook-form": "7.72.1",
    "react-images-uploading": "3.1.7",
    "react-responsive": "10.0.1",
    "react-router-bootstrap": "0.26.3",
    "react-router-dom": "7.14.0",
    "react-webcam": "7.2.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@types/lodash": "4.17.24",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-bootstrap": "0.26.8",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "html-minifier": "4.0.0",
    "prettier": "3.8.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-plugin-favicons-inject": "2.2.0"
  }
}
